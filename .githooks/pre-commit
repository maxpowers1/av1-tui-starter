#!/usr/bin/env bash
# Pre-commit hook: fast checks only (seconds, not minutes).
# Heavy checks (pytest, mypy, ADR compliance) live in /qa.
#
# Setup: git config core.hooksPath .githooks

set -e

# Resolve uv — git hooks inherit a minimal PATH
UV=$(command -v uv 2>/dev/null \
    || echo "$HOME/.local/bin/uv" \
    || echo "$HOME/.cargo/bin/uv")
if [ ! -x "$UV" ]; then
    echo "pre-commit: uv not found. Install it or skip with --no-verify."
    exit 1
fi

# Find Python files that are staged for commit
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$STAGED_PY" ]; then
    exit 0
fi

echo "pre-commit: checking staged Python files..."

# Lint
if ! $UV run ruff check $STAGED_PY; then
    echo ""
    echo "pre-commit: ruff check failed. Fix lint errors or run '$UV run ruff check --fix'."
    exit 1
fi

# Format
if ! $UV run ruff format --check $STAGED_PY; then
    echo ""
    echo "pre-commit: ruff format failed. Run '$UV run ruff format' to fix."
    exit 1
fi

echo "pre-commit: passed."
